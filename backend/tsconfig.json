{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "allowJs": true,
    "outDir": "dist",
    "strict": false
  },
  "include": ["src"]
}
